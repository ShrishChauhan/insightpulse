# InsightPulse — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Supabase ────────────────────────────────────────────────────────────────
# Use the service_role key (NOT anon key) — find it in project Settings → API.
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-service-role-key

# ── LLM Provider ────────────────────────────────────────────────────────────
# Set PROVIDER to "groq" (default, free) | "gemini" (free) | "anthropic" (prod)
PROVIDER=groq
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Data Sources ─────────────────────────────────────────────────────────────
# Reddit API closed to new developers May 2026 — replaced with Bluesky,
# YouTube, ProductHunt, and App Store sources.
# Bluesky and App Store require no credentials.

# Serper.dev (Gold Mining — Google SERP API): serper.dev → Sign up with Google
# (no credit card required) → copy API key. Free 2500 lifetime searches.
SERPER_API_KEY=

# YouTube Data API v3: Google Cloud Console → YouTube Data API v3 → Create API key.
YOUTUBE_API_KEY=

# ProductHunt: producthunt.com/v2/oauth/applications → Create app → Developer Token.
PRODUCTHUNT_TOKEN=

# ── Zernio (recommended — posts to LinkedIn company page) ───────────────────
# Sign up free at zernio.com, connect LinkedIn, copy API key.
# Get ZERNIO_ACCOUNT_ID from Zernio dashboard -> Connections.
# ZERNIO_ORGANIZATION_URN: your LinkedIn company page org URN.
ZERNIO_API_KEY=
ZERNIO_ACCOUNT_ID=
ZERNIO_ORGANIZATION_URN=urn:li:organization:

# ── LinkedIn (direct API — future migration from Buffer) ─────────────────────
# Create a LinkedIn app at developers.linkedin.com → request "Share on LinkedIn".
# LINKEDIN_PERSON_URN: your profile URN, format urn:li:person:XXXXXXXX
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# LinkedIn Company Page (recommended — post as InsightPulse, not your personal account)
# Get org ID from your LinkedIn company page URL (linkedin.com/company/<id>)
LINKEDIN_ORGANIZATION_URN=urn:li:organization:

# ── Buffer (legacy LinkedIn posting, currently active) ───────────────────────
# Get access token: buffer.com → Settings → Apps & API → Create App → OAuth.
# Get profile ID: run BufferPoster(db).get_profiles() after setting token above.
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=

# ── Notifications ────────────────────────────────────────────────────────────
# Slack incoming webhook URL — leave blank to use console-only fallback.
SLACK_WEBHOOK_URL=
