# InsightPulse — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Supabase ────────────────────────────────────────────────────────────────
# Use the service_role key (NOT anon key) — find it in project Settings → API.
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-service-role-key

# ── LLM Provider ────────────────────────────────────────────────────────────
# Set PROVIDER to "groq" (default, free) | "gemini" (free) | "anthropic" (prod)
PROVIDER=groq
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Reddit ───────────────────────────────────────────────────────────────────
# Create a script-type app at reddit.com/prefs/apps to get client ID and secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=InsightPulse/1.0 by your_username

# ── LinkedIn (direct API — future migration from Buffer) ─────────────────────
# Create a LinkedIn app at developers.linkedin.com → request "Share on LinkedIn".
# LINKEDIN_PERSON_URN: your profile URN, format urn:li:person:XXXXXXXX
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ── Buffer (legacy LinkedIn posting, currently active) ───────────────────────
# Get access token: buffer.com → Settings → Apps & API → Create App → OAuth.
# Get profile ID: run BufferPoster(db).get_profiles() after setting token above.
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=

# ── Notifications ────────────────────────────────────────────────────────────
# Slack incoming webhook URL — leave blank to use console-only fallback.
SLACK_WEBHOOK_URL=
